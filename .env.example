# ── Copy to .env and adjust ──────────────────────────────────────────────────
# Usage: cp .env.example .env && set -a && . .env && set +a

# ── Database ─────────────────────────────────────────────────────────────────
PG_HOST=192.168.88.101          # any node IP — PgPool handles routing
PG_DATABASE=postgres
PG_USER=postgres
PG_PASSWORD=ChangeMe_Postgres1
PG_WRITE_PORT=9999              # Stack A: PgPool  |  Stack B: 30432
PG_READ_PORT=9999               # Stack A: PgPool  |  Stack B: 30432

# ── SQL files ─────────────────────────────────────────────────────────────────
# SQL_DIR=./sql                 # default: sql/ next to this file

# ── Locust web UI / API ───────────────────────────────────────────────────────
LOCUST_WEB_HOST=0.0.0.0
LOCUST_WEB_PORT=8089

# ── Reports ───────────────────────────────────────────────────────────────────
# REPORTS_DIR=./reports         # default: reports/ next to this file

# ── HA lab control (used by run_scenarios.py failure injection) ───────────────
LAB_NODE1_IP=192.168.88.101
LAB_NODE2_IP=192.168.88.102
LAB_NODE3_IP=192.168.88.103
PATRONI_REST_PORT=8008          # health gates + leader detection
PATRONICTL="ssh node1 sudo patronictl -c /etc/patroni/config.yml"
DOCKER_KILL="docker kill"
DOCKER_START="docker start"

# ── Per-scenario commands (named; override individually) ─────────────────────
# Placeholders resolved at injection time against live cluster state:
#   {leader}  = current Patroni leader     {replica} = a streaming replica
#   {target}  = node the inject command hit (used by the recovery command)
# *_STABLE_CMD: optional extra stability check run AFTER recovery — the runner
# retries it until exit code 0. The built-in gate (1 leader + 2 streaming
# replicas + write through PgPool) always runs first.
#
# Defaults (docker lab) — uncomment to override:
# LEADER_CRASH_INJECT_CMD="docker kill {leader}"
# LEADER_CRASH_RECOVERY_CMD="docker start {target}"
# LEADER_CRASH_STABLE_CMD=""
# SWITCHOVER_INJECT_CMD="ssh node1 sudo patronictl -c /etc/patroni/config.yml switchover pgcluster --force"
# SWITCHOVER_RECOVERY_CMD=""    # graceful op — nothing to recover
# SWITCHOVER_STABLE_CMD=""
# REPLICA_POWEROFF_INJECT_CMD="docker kill {replica}"
# REPLICA_POWEROFF_RECOVERY_CMD="docker start {target}"
# REPLICA_POWEROFF_STABLE_CMD=""

# ── For Hetzner / remote VMs ─────────────────────────────────────────────────
# PG_HOST=<floating-ip-or-lb>
# PG_WRITE_PORT=9999
# PATRONICTL="ssh ubuntu@<node1-public-ip> sudo patronictl -c /etc/patroni/config.yml"
# LEADER_CRASH_INJECT_CMD="hcloud server poweroff {leader}"
# LEADER_CRASH_RECOVERY_CMD="hcloud server poweron {target}"
# LEADER_CRASH_STABLE_CMD="ssh ubuntu@<node1-public-ip> sudo patronictl -c /etc/patroni/config.yml list | grep -c streaming | grep -q 2"
# REPLICA_POWEROFF_INJECT_CMD="hcloud server poweroff {replica}"
# REPLICA_POWEROFF_RECOVERY_CMD="hcloud server poweron {target}"
